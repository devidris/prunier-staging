<div class="product-comment-list-item text-center" data-product-comment-id="@COMMENT_ID@" data-product-id="@PRODUCT_ID@">

  <div class="comment-content border-0 mb-4">@COMMENT_COMMENT@</div>
  <div class="comment-author text-muted">
    {l s='Written by' d='Shop.CreathemeModules'} <span class="comment-customer-name font-weight-bold">@CUSTOMER_NAME@</span>
    {l s='on' d='Shop.CreathemeModules'} @COMMENT_DATE@
  </div>

</div>
